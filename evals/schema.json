{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hyrule Engineering Loop private eval case",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "family",
    "title",
    "input",
    "expected_decision"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string"
    },
    "family": {
      "enum": [
        "domain-policy",
        "promotion-safety",
        "noc-evidence",
        "vps-launch-proof",
        "network-change"
      ]
    },
    "title": {
      "type": "string"
    },
    "input": {
      "type": "object",
      "properties": {
        "issue_title": {
          "type": "string"
        },
        "issue_body": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "changed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "must_include": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "must_not_include": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_decision": {
      "enum": [
        "approve",
        "request_human_review",
        "reject"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
